@model List<EventRescue.Models.EventRequest>
@using EventRescue.Models.Enums

@{
    ViewData["Title"] = "طلباتي";

    int totalRequests = Model?.Count ?? 0;
    int pendingRequests = Model?.Count(r => r.Status == EventStatus.Pending) ?? 0;
    int acceptedRequests = Model?.Count(r => r.Status == EventStatus.Accepted) ?? 0;
    int completedRequests = Model?.Count(r => r.Status == EventStatus.Completed) ?? 0;
    int canceledRequests = Model?.Count(r => r.Status == EventStatus.Canceled) ?? 0;
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.22), transparent 30%),
            radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.14), transparent 30%),
            #8396c89f;
    }

    .requests-dashboard {
        direction: rtl;
        color: #e5e7eb;
    }

    .dark-panel {
        background: rgba(15, 23, 42, 0.573);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 30px;
        box-shadow: 0 28px 70px rgba(0, 0, 0, 0.32);
        backdrop-filter: blur(16px);
    }

    .requests-hero {
        padding: 34px;
        margin-bottom: 24px;
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.30), transparent 36%),
            linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.92));
        overflow: hidden;
        position: relative;
    }

    .requests-hero::before {
        content: "";
        position: absolute;
        width: 230px;
        height: 230px;
        border-radius: 50%;
        background: rgba(37, 99, 235, 0.22);
        left: -80px;
        bottom: -90px;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(96, 165, 250, 0.15);
        border: 1px solid rgba(96, 165, 250, 0.25);
        color: #bfdbfe;
        border-radius: 999px;
        padding: 8px 15px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .hero-title {
        color: white;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .hero-text {
        color: #94a3b8;
        line-height: 1.8;
        margin-bottom: 0;
    }

    .hero-action {
        border-radius: 999px;
        font-weight: 800;
        padding: 12px 24px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: rgba(15, 23, 42, 0.76);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 24px;
        padding: 20px;
        transition: 0.2s ease;
        min-height: 150px;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        border-color: rgba(96, 165, 250, 0.45);
        box-shadow: 0 22px 48px rgba(37, 99, 235, 0.18);
    }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: rgba(37, 99, 235, 0.16);
        color: #60a5fa;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        margin-bottom: 12px;
    }

    .stat-number {
        font-size: 1.9rem;
        font-weight: 900;
        color: white;
        margin-bottom: 3px;
    }

    .stat-label {
        color: #94a3b8;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .requests-toolbar {
        padding: 22px;
        margin-bottom: 24px;
    }

    .toolbar-title {
        color: white;
        font-weight: 900;
        margin-bottom: 5px;
    }

    .toolbar-text {
        color: #94a3b8;
        margin-bottom: 0;
    }

    .requests-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .request-card {
        background: rgba(15, 23, 42, 0.76);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.24);
        transition: 0.22s ease;
        height: 100%;
    }

    .request-card:hover {
        transform: translateY(-7px);
        border-color: rgba(96, 165, 250, 0.45);
        box-shadow: 0 28px 70px rgba(37, 99, 235, 0.20);
    }

    .request-image {
        width: 100%;
        height: 205px;
        object-fit: cover;
        display: block;
    }

    .image-placeholder {
        height: 205px;
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.35), transparent 40%),
            rgba(30, 41, 59, 0.82);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #60a5fa;
        font-size: 3rem;
    }

    .request-body {
        padding: 22px;
    }

    .request-title {
        color: white;
        font-weight: 900;
        margin-bottom: 0;
        line-height: 1.5;
    }

    .request-description {
        color: #94a3b8;
        line-height: 1.8;
        margin: 16px 0;
        min-height: 55px;
    }

    .status-pill {
        border-radius: 999px;
        padding: 7px 13px;
        font-size: 0.82rem;
        font-weight: 900;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-pending {
        background: rgba(251, 146, 60, 0.16);
        color: #fdba74;
    }

    .status-accepted {
        background: rgba(14, 165, 233, 0.16);
        color: #7dd3fc;
    }

    .status-completed {
        background: rgba(34, 197, 94, 0.16);
        color: #86efac;
    }

    .status-canceled {
        background: rgba(239, 68, 68, 0.16);
        color: #fca5a5;
    }

    .info-list {
        display: grid;
        gap: 10px;
        margin-bottom: 18px;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #cbd5e1;
        background: rgba(30, 41, 59, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 16px;
        padding: 11px 12px;
        font-size: 0.92rem;
    }

    .info-row i {
        color: #60a5fa;
        flex-shrink: 0;
    }

    .card-footer-custom {
        border-top: 1px solid rgba(148, 163, 184, 0.14);
        padding-top: 16px;
        margin-top: 16px;
    }

    .muted {
        color: #94a3b8;
    }

    .empty-box {
        text-align: center;
        padding: 55px 24px;
    }

    .empty-icon {
        width: 86px;
        height: 86px;
        border-radius: 28px;
        background: rgba(37, 99, 235, 0.16);
        color: #60a5fa;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.8rem;
        margin-bottom: 18px;
    }

    @@media (max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .requests-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid,
        .requests-grid {
            grid-template-columns: 1fr;
        }

        .requests-hero {
            padding: 26px;
        }
    }
</style>

<div class="container requests-dashboard mt-5 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4 text-center">
            @TempData["SuccessMessage"]
        </div>
    }

    <section class="dark-panel requests-hero">
        <div class="hero-content">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="hero-badge">
                        <i class="bi bi-list-check"></i>
                        متابعة الطلبات
                    </div>

                    <h1 class="hero-title">
                        طلباتي
                    </h1>

                    <p class="hero-text">
                        تابعي جميع الطلبات التي أرسلتيها، حالة كل طلب، وتفاصيل الخدمة المطلوبة في مكان واحد.
                    </p>
                </div>

                <div class="col-lg-4 text-lg-start text-center mt-4 mt-lg-0">
                    <a asp-action="Create" class="btn btn-primary hero-action">
                        <i class="bi bi-plus-circle"></i>
                        إنشاء طلب جديد
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="stats-grid">

        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-folder2-open"></i>
            </div>
            <div class="stat-number">@totalRequests</div>
            <div class="stat-label">إجمالي الطلبات</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div class="stat-number">@pendingRequests</div>
            <div class="stat-label">متاحة للعروض</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-check2-circle"></i>
            </div>
            <div class="stat-number">@acceptedRequests</div>
            <div class="stat-label">طلبات مقبولة</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-patch-check"></i>
            </div>
            <div class="stat-number">@completedRequests</div>
            <div class="stat-label">طلبات مكتملة</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-x-circle"></i>
            </div>
            <div class="stat-number">@canceledRequests</div>
            <div class="stat-label">طلبات ملغية</div>
        </div>

    </section>

    <section class="dark-panel requests-toolbar">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h4 class="toolbar-title">
                    قائمة الطلبات
                </h4>

                <p class="toolbar-text">
                    تعرض هذه الصفحة الطلبات مرتبة من الأحدث إلى الأقدم.
                </p>
            </div>

            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-light rounded-pill fw-bold">
                <i class="bi bi-arrow-right"></i>
                العودة للوحة المستخدم
            </a>
        </div>
    </section>

    @if (Model == null || !Model.Any())
    {
        <section class="dark-panel empty-box">
            <div class="empty-icon">
                <i class="bi bi-inbox"></i>
            </div>

            <h4 class="fw-bold text-white">
                لا توجد طلبات حتى الآن
            </h4>

            <p class="muted mb-4">
                ابدئي بإنشاء طلب جديد ليظهر لمزودي الخدمة المناسبين حسب المدينة ونوع الخدمة.
            </p>

            <a asp-action="Create" class="btn btn-primary rounded-pill fw-bold px-4">
                <i class="bi bi-plus-circle"></i>
                إنشاء طلب جديد
            </a>
        </section>
    }
    else
    {
        <section class="requests-grid">

            @foreach (var request in Model)
            {
                string statusText = request.Status switch
                {
                    EventStatus.Pending => "متاح للعروض",
                    EventStatus.Accepted => "مقبول",
                    EventStatus.Completed => "مكتمل",
                    EventStatus.Canceled => "ملغي",
                    _ => "غير معروف"
                };

                string statusClass = request.Status switch
                {
                    EventStatus.Pending => "status-pending",
                    EventStatus.Accepted => "status-accepted",
                    EventStatus.Completed => "status-completed",
                    EventStatus.Canceled => "status-canceled",
                    _ => "status-pending"
                };

                string statusIcon = request.Status switch
                {
                    EventStatus.Pending => "bi-hourglass-split",
                    EventStatus.Accepted => "bi-check2-circle",
                    EventStatus.Completed => "bi-patch-check",
                    EventStatus.Canceled => "bi-x-circle",
                    _ => "bi-info-circle"
                };

                <div class="request-card">

                    @if (!string.IsNullOrEmpty(request.ImagePath))
                    {
                        <img src="@request.ImagePath"
                             class="request-image"
                             alt="صورة الطلب" />
                    }
                    else
                    {
                        <div class="image-placeholder">
                            <i class="bi bi-image"></i>
                        </div>
                    }

                    <div class="request-body">

                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h5 class="request-title">
                                @request.Title
                            </h5>

                            <span class="status-pill @statusClass">
                                <i class="bi @statusIcon"></i>
                                @statusText
                            </span>
                        </div>

                        <p class="request-description">
                            @request.Description
                        </p>

                        <div class="info-list">

                            <div class="info-row">
                                <i class="bi bi-tools"></i>
                                <span>
                                    <strong>الخدمة:</strong>
                                    @(request.Category?.Name ?? "غير محدد")
                                </span>
                            </div>

                            <div class="info-row">
                                <i class="bi bi-calendar-event"></i>
                                <span>
                                    <strong>تاريخ المناسبة:</strong>
                                    @request.EventDate.ToString("yyyy/MM/dd")
                                </span>
                            </div>

                            <div class="info-row">
                                <i class="bi bi-geo-alt"></i>
                                <span>
                                    <strong>المدينة:</strong>
                                    @(request.Region?.Name ?? "غير محددة")
                                </span>
                            </div>

                            <div class="info-row">
                                <i class="bi bi-house-door"></i>
                                <span>
                                    <strong>العنوان:</strong>
                                    @request.Address
                                </span>
                            </div>

                        </div>

                        <div class="card-footer-custom">
                            <div class="muted small mb-3">
                                <i class="bi bi-clock text-info"></i>
                                تاريخ الإرسال:
                                @request.CreatedAt.ToString("yyyy/MM/dd")
                            </div>

                            <a asp-action="Details"
                               asp-route-id="@request.Id"
                               class="btn btn-outline-light w-100 rounded-pill fw-bold">
                                <i class="bi bi-eye"></i>
                                عرض التفاصيل
                            </a>
                        </div>

                    </div>
                </div>
            }

        </section>
    }

</div>