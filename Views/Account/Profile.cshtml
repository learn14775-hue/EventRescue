@model EventRescue.Models.ApplicationUser
@using EventRescue.Models
@using EventRescue.Models.Enums

@{
    ViewData["Title"] = "لوحة المستخدم";

    string accountTypeName = Model.AccountType == UserType.Provider ? "مزود خدمة" : "مستفيد";
    bool isClient = Model.AccountType == UserType.Client;
    bool isProvider = Model.AccountType == UserType.Provider;

    int totalRequests = ViewBag.TotalRequests != null ? (int)ViewBag.TotalRequests : 0;
    int pendingRequests = ViewBag.PendingRequests != null ? (int)ViewBag.PendingRequests : 0;
    int acceptedRequests = ViewBag.AcceptedRequests != null ? (int)ViewBag.AcceptedRequests : 0;
    int canceledRequests = ViewBag.CanceledRequests != null ? (int)ViewBag.CanceledRequests : 0;

    EventRequest? latestRequest = ViewBag.LatestRequest as EventRequest;

    string phoneText = string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "غير مضاف" : Model.PhoneNumber;
    string firstLetter = string.IsNullOrWhiteSpace(Model.FullName) ? "U" : Model.FullName.Trim().Substring(0, 1);
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.22), transparent 30%),
            radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.14), transparent 30%),
            #8396c89f;
    }

    .profile-dashboard {
        direction: rtl;
        color: #e5e7eb;
    }

    .dash-layout {
        display: grid;
        grid-template-columns: 330px 1fr;
        gap: 24px;
    }

    .dark-panel {
        background: rgba(15, 23, 42, 0.573);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 30px;
        box-shadow: 0 28px 70px rgba(0, 0, 0, 0.32);
        backdrop-filter: blur(16px);
    }

    .side-panel {
        padding: 28px;
        min-height: 660px;
        position: sticky;
        top: 24px;
        overflow: hidden;
    }

    .side-panel::before {
        content: "";
        position: absolute;
        width: 210px;
        height: 210px;
        background: rgba(37, 99, 235, 0.24);
        border-radius: 50%;
        top: -90px;
        left: -70px;
    }

    .side-content {
        position: relative;
        z-index: 2;
    }

    .avatar {
        width: 96px;
        height: 96px;
        border-radius: 30px;
        background: linear-gradient(135deg, #2563eb, #38bdf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        box-shadow: 0 18px 40px rgba(37, 99, 235, 0.38);
        margin-bottom: 20px;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(96, 165, 250, 0.28);
        color: #bfdbfe;
        border-radius: 999px;
        padding: 8px 14px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .user-name {
        font-size: 1.65rem;
        font-weight: 900;
        margin-bottom: 6px;
        color: #ffffff;
    }

    .user-email {
        color: #94a3b8;
        word-break: break-word;
        margin-bottom: 26px;
    }

    .side-line {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #cbd5e1;
        padding: 13px 0;
        border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    }

    .side-line i {
        color: #38bdf8;
    }

    .side-actions {
        margin-top: 26px;
        display: grid;
        gap: 10px;
    }

    .side-actions .btn {
        border-radius: 999px;
        font-weight: 800;
        padding: 11px;
    }

    .main-area {
        display: grid;
        gap: 24px;
    }

    .top-hero {
        padding: 32px;
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.30), transparent 36%),
            linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.92));
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(96, 165, 250, 0.15);
        border: 1px solid rgba(96, 165, 250, 0.25);
        color: #bfdbfe;
        border-radius: 999px;
        padding: 8px 15px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .hero-title {
        font-weight: 900;
        color: white;
        margin-bottom: 10px;
    }

    .hero-text {
        color: #94a3b8;
        line-height: 1.8;
        margin-bottom: 0;
    }

    .hero-action {
        border-radius: 999px;
        font-weight: 800;
        padding: 12px 24px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .stat-card {
        background: rgba(15, 23, 42, 0.76);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 24px;
        padding: 22px;
        transition: 0.2s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        border-color: rgba(96, 165, 250, 0.45);
        box-shadow: 0 22px 48px rgba(37, 99, 235, 0.18);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: rgba(37, 99, 235, 0.16);
        color: #60a5fa;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        margin-bottom: 14px;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 900;
        color: white;
        margin-bottom: 3px;
    }

    .stat-label {
        color: #94a3b8;
        font-weight: 700;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
    }

    .card-title {
        color: white;
        font-weight: 900;
        margin-bottom: 20px;
    }

    .info-list {
        display: grid;
        gap: 12px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 13px;
        background: rgba(30, 41, 59, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 18px;
        padding: 15px;
    }

    .info-icon {
        width: 46px;
        height: 46px;
        border-radius: 15px;
        background: rgba(37, 99, 235, 0.16);
        color: #60a5fa;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .info-label {
        color: #94a3b8;
        font-size: 0.88rem;
        margin-bottom: 3px;
    }

    .info-value {
        color: white;
        font-weight: 900;
        word-break: break-word;
    }

    .action-list {
        display: grid;
        gap: 12px;
    }

    .action-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        background: rgba(30, 41, 59, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.14);
        color: #e5e7eb;
        text-decoration: none;
        border-radius: 18px;
        padding: 16px;
        transition: 0.2s ease;
    }

    .action-link:hover {
        color: white;
        background: rgba(37, 99, 235, 0.18);
        border-color: rgba(57, 77, 102, 0.38);
        transform: translateX(-4px);
    }

    .action-link i {
        color: #60a5fa;
    }

    .latest-card {
        background: rgba(30, 41, 59, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 22px;
        padding: 22px;
    }

    .status-pill {
        border-radius: 999px;
        padding: 7px 13px;
        font-size: 0.85rem;
        font-weight: 900;
        white-space: nowrap;
    }

    .status-pending {
        background: rgba(251, 146, 60, 0.16);
        color: #fdba74;
    }

    .status-accepted {
        background: rgba(14, 165, 233, 0.16);
        color: #7dd3fc;
    }

    .status-completed {
        background: rgba(34, 197, 94, 0.16);
        color: #86efac;
    }

    .status-canceled {
        background: rgba(239, 68, 68, 0.16);
        color: #fca5a5;
    }

    .empty-box {
        text-align: center;
        padding: 35px 20px;
        border-radius: 22px;
        border: 1px dashed rgba(148, 163, 184, 0.25);
        background: rgba(30, 41, 59, 0.48);
    }

    .muted {
        color: #94a3b8;
    }

    @@media (max-width: 992px) {
        .dash-layout {
            grid-template-columns: 1fr;
        }

        .side-panel {
            min-height: auto;
            position: static;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .top-hero {
            padding: 24px;
        }
    }
</style>

<div class="container profile-dashboard mt-5 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4 text-center">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="dash-layout">

        <aside class="dark-panel side-panel">
            <div class="side-content">

                <div class="avatar">
                    @firstLetter
                </div>

                <div class="role-badge">
                    <i class="bi bi-person-badge"></i>
                    @accountTypeName
                </div>

                <div class="user-name">
                    @Model.FullName
                </div>

                <div class="user-email">
                    @Model.Email
                </div>

                <div class="side-line">
                    <i class="bi bi-telephone"></i>
                    <span>@phoneText</span>
                </div>

                <div class="side-line">
                    <i class="bi bi-geo-alt"></i>
                    <span>@(Model.Region?.Name ?? "غير محددة")</span>
                </div>

                <div class="side-line">
                    <i class="bi bi-person-check"></i>
                    <span>@accountTypeName</span>
                </div>

                @if (isProvider)
                {
                    <div class="side-line">
                        <i class="bi bi-briefcase"></i>
                        <span>@(Model.Specialty?.Name ?? "غير محدد")</span>
                    </div>
                }

                <div class="side-actions">
                    <a asp-action="EditProfile" class="btn btn-light">
                        <i class="bi bi-pencil-square"></i>
                        تعديل الملف الشخصي
                    </a>

                    @if (isClient)
                    {
                        <a asp-controller="EventRequests" asp-action="Create" class="btn btn-outline-light">
                            <i class="bi bi-plus-circle"></i>
                            طلب جديد
                        </a>

                        <a asp-controller="EventRequests" asp-action="MyRequests" class="btn btn-outline-light">
                            <i class="bi bi-list-check"></i>
                            طلباتي
                        </a>
                    }

                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-house"></i>
                        الرئيسية
                    </a>

                    <form asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-outline-light w-100">
                            <i class="bi bi-box-arrow-right"></i>
                            تسجيل الخروج
                        </button>
                    </form>
                </div>

            </div>
        </aside>

        <main class="main-area">

            <section class="dark-panel top-hero">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <div class="hero-badge">
                            <i class="bi bi-speedometer2"></i>
                            لوحة المستخدم
                        </div>

                        <h1 class="hero-title">
                            مرحبًا، @Model.FullName
                        </h1>

                        <p class="hero-text">
                            يمكنك من هنا إدارة حسابك، إنشاء طلب جديد، ومتابعة حالة الطلبات الخاصة بك.
                        </p>
                    </div>

                    @if (isClient)
                    {
                        <a asp-controller="EventRequests" asp-action="Create" class="btn btn-primary hero-action">
                            <i class="bi bi-plus-circle"></i>
                            إنشاء طلب جديد
                        </a>
                    }
                </div>
            </section>

            @if (isClient)
            {
                <section class="stats-grid">

                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="bi bi-folder2-open"></i>
                        </div>
                        <div class="stat-number">@totalRequests</div>
                        <div class="stat-label">إجمالي الطلبات</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                        <div class="stat-number">@pendingRequests</div>
                        <div class="stat-label">متاحة للعروض</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                        <div class="stat-number">@acceptedRequests</div>
                        <div class="stat-label">مقبولة</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="bi bi-x-circle"></i>
                        </div>
                        <div class="stat-number">@canceledRequests</div>
                        <div class="stat-label">ملغية</div>
                    </div>

                </section>
            }

            <section class="content-grid">

                <div class="dark-panel p-4">
                    <h4 class="card-title">
                        بيانات الحساب
                    </h4>

                    <div class="info-list">

                        <div class="info-item">
                            <span class="info-icon">
                                <i class="bi bi-person"></i>
                            </span>

                            <div>
                                <div class="info-label">الاسم الكامل</div>
                                <div class="info-value">@Model.FullName</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <span class="info-icon">
                                <i class="bi bi-envelope"></i>
                            </span>

                            <div>
                                <div class="info-label">البريد الإلكتروني</div>
                                <div class="info-value">@Model.Email</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <span class="info-icon">
                                <i class="bi bi-telephone"></i>
                            </span>

                            <div>
                                <div class="info-label">رقم الجوال</div>
                                <div class="info-value">@phoneText</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <span class="info-icon">
                                <i class="bi bi-geo-alt"></i>
                            </span>

                            <div>
                                <div class="info-label">المدينة</div>
                                <div class="info-value">@(Model.Region?.Name ?? "غير محددة")</div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="dark-panel p-4">
                    <h4 class="card-title">
                        إجراءات سريعة
                    </h4>

                    <div class="action-list">
                        <a asp-action="EditProfile" class="action-link">
                            <span>
                                <i class="bi bi-pencil-square ms-2"></i>
                                تعديل بيانات الحساب
                            </span>
                            <i class="bi bi-chevron-left"></i>
                        </a>

                        @if (isClient)
                        {
                            <a asp-controller="EventRequests" asp-action="Create" class="action-link">
                                <span>
                                    <i class="bi bi-plus-circle ms-2"></i>
                                    إنشاء طلب جديد
                                </span>
                                <i class="bi bi-chevron-left"></i>
                            </a>

                            <a asp-controller="EventRequests" asp-action="MyRequests" class="action-link">
                                <span>
                                    <i class="bi bi-list-check ms-2"></i>
                                    عرض طلباتي
                                </span>
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }

                        <a asp-controller="Home" asp-action="Index" class="action-link">
                            <span>
                                <i class="bi bi-house ms-2"></i>
                                العودة للرئيسية
                            </span>
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </div>
                </div>

            </section>

            <section class="dark-panel p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <div>
                        <h4 class="card-title mb-1">
                            آخر نشاط
                        </h4>
                        <p class="muted mb-0">
                            آخر طلب أو عملية مرتبطة بحسابك.
                        </p>
                    </div>

                    @if (isClient)
                    {
                        <a asp-controller="EventRequests" asp-action="MyRequests" class="btn btn-outline-light rounded-pill fw-bold">
                            عرض الكل
                        </a>
                    }
                </div>

                @if (isClient)
                {
                    if (latestRequest != null)
                    {
                        string statusText = latestRequest.Status switch
                        {
                            EventStatus.Pending => "متاح للعروض",
                            EventStatus.Accepted => "مقبول",
                            EventStatus.Completed => "مكتمل",
                            EventStatus.Canceled => "ملغي",
                            _ => "غير معروف"
                        };

                        string statusClass = latestRequest.Status switch
                        {
                            EventStatus.Pending => "status-pending",
                            EventStatus.Accepted => "status-accepted",
                            EventStatus.Completed => "status-completed",
                            EventStatus.Canceled => "status-canceled",
                            _ => "status-pending"
                        };

                        <div class="latest-card">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="fw-bold text-white mb-1">
                                        @latestRequest.Title
                                    </h5>

                                    <div class="muted">
                                        @(latestRequest.Category?.Name ?? "غير محدد")
                                    </div>
                                </div>

                                <span class="status-pill @statusClass">
                                    @statusText
                                </span>
                            </div>

                            <div class="d-flex flex-wrap gap-3 muted small mb-4">
                                <span>
                                    <i class="bi bi-calendar-event text-info"></i>
                                    @latestRequest.EventDate.ToString("yyyy/MM/dd")
                                </span>

                                <span>
                                    <i class="bi bi-clock text-info"></i>
                                    @latestRequest.CreatedAt.ToString("yyyy/MM/dd")
                                </span>
                            </div>

                            <a asp-controller="EventRequests"
                               asp-action="Details"
                               asp-route-id="@latestRequest.Id"
                               class="btn btn-primary rounded-pill fw-bold">
                                <i class="bi bi-eye"></i>
                                عرض التفاصيل
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">
                            <i class="bi bi-inbox text-info" style="font-size: 3rem;"></i>

                            <h5 class="fw-bold text-white mt-3">
                                لا توجد طلبات حتى الآن
                            </h5>

                            <p class="muted">
                                ابدأ بإنشاء أول طلب وسيظهر هنا.
                            </p>

                            <a asp-controller="EventRequests" asp-action="Create" class="btn btn-primary rounded-pill fw-bold">
                                إنشاء طلب
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="latest-card">
                        <h5 class="fw-bold text-white">
                            حساب مزود خدمة
                        </h5>

                        <p class="muted mb-0">
                            يمكن تعديل التخصص وحالة التوفر من صفحة تعديل الملف الشخصي.
                        </p>
                    </div>
                }
            </section>

        </main>

    </div>

</div>