@model EventRescue.ViewModels.EditProfileViewModel
@using EventRescue.Models

@{
    ViewData["Title"] = "تعديل الملف الشخصي";

    var regions = ViewBag.Regions as List<Region>;
    var categories = ViewBag.Categories as List<Category>;

    bool isProvider = User.IsInRole("Provider");
}

<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(147, 197, 253, 0.25), transparent 28%),
            radial-gradient(circle at bottom left, rgba(187, 247, 208, 0.20), transparent 30%),
            #f4f7fb;
    }

    .edit-page {
        direction: rtl;
        color: #1f2937;
    }

    .edit-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #dbe7f3;
        border-radius: 30px;
        box-shadow: 0 18px 45px rgba(71, 85, 105, 0.10);
        overflow: hidden;
    }

    .edit-top {
        background: linear-gradient(135deg, #eaf3ff, #eefbf3);
        padding: 32px;
        border-bottom: 1px solid #dbeafe;
    }

    .edit-icon {
        width: 72px;
        height: 72px;
        border-radius: 24px;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 15px;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.20);
    }

    .edit-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 6px;
    }

    .edit-subtitle {
        color: #64748b;
        margin-bottom: 0;
    }

    .edit-body {
        padding: 30px;
    }

    .field-box {
        background: #f8fbff;
        border: 1px solid #dbeafe;
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .form-label {
        font-weight: 900;
        color: #243b53;
        margin-bottom: 10px;
    }

    .form-control,
    .form-select {
        border-radius: 16px;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #7dd3fc;
        box-shadow: 0 0 0 0.18rem rgba(14, 165, 233, 0.13);
    }

    .save-btn {
        border-radius: 999px;
        padding: 12px;
        font-weight: 900;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        border: 0;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.18);
    }

    .save-btn:hover {
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
    }

    .back-btn {
        border-radius: 999px;
        font-weight: 800;
        padding: 11px;
    }

    .provider-note {
        background: #eefbf3;
        border: 1px solid #bbf7d0;
        color: #166534;
        border-radius: 18px;
        padding: 14px 16px;
        font-weight: 700;
    }
</style>

<div class="container edit-page mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">

            <div class="edit-card">

                <div class="edit-top text-center">
                    <div class="edit-icon">
                        <i class="bi bi-pencil-square"></i>
                    </div>

                    <h3 class="edit-title">
                        تعديل الملف الشخصي
                    </h3>

                    <p class="edit-subtitle">
                        حدّثي بيانات حسابك الأساسية
                    </p>
                </div>

                <div class="edit-body">

                    <form asp-action="EditProfile" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="field-box">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="field-box">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="05xxxxxxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="field-box">
                            <label asp-for="RegionId" class="form-label"></label>

                            <select asp-for="RegionId" class="form-select">
                                <option value="">-- اختاري المدينة --</option>

                                @if (regions != null)
                                {
                                    foreach (var region in regions)
                                    {
                                        <option value="@region.Id">@region.Name</option>
                                    }
                                }
                            </select>

                            <span asp-validation-for="RegionId" class="text-danger"></span>
                        </div>

                        @if (isProvider)
                        {
                            <div class="provider-note mb-3">
                                <i class="bi bi-briefcase"></i>
                                بيانات مزود الخدمة
                            </div>

                            <div class="field-box">
                                <label asp-for="CategoryId" class="form-label"></label>

                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">-- اختاري التخصص --</option>

                                    @if (categories != null)
                                    {
                                        foreach (var category in categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    }
                                </select>

                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>

                            <div class="field-box">
                                <div class="form-check">
                                    <input asp-for="IsAvailableNow" class="form-check-input" />
                                    <label asp-for="IsAvailableNow" class="form-check-label fw-bold"></label>
                                </div>
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100 save-btn">
                            <i class="bi bi-check-circle"></i>
                            حفظ التعديلات
                        </button>

                        <a asp-action="Profile" class="btn btn-outline-secondary w-100 back-btn mt-3">
                            <i class="bi bi-arrow-right"></i>
                            العودة للملف الشخصي
                        </a>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}