@model EventRescue.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "تسجيل الدخول";
}

<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(147, 197, 253, 0.25), transparent 28%),
            radial-gradient(circle at bottom left, rgba(187, 247, 208, 0.20), transparent 30%),
            #f4f7fb;
    }

    .login-page {
        direction: rtl;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #dbe7f3;
        border-radius: 28px;
        box-shadow: 0 18px 45px rgba(71, 85, 105, 0.10);
        overflow: hidden;
    }

    .login-top {
        background: linear-gradient(135deg, #eaf3ff, #eefbf3);
        padding: 30px 24px;
        text-align: center;
        border-bottom: 1px solid #dbeafe;
    }

    .login-icon {
        width: 72px;
        height: 72px;
        border-radius: 24px;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 15px;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.20);
    }

    .login-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 6px;
    }

    .login-subtitle {
        color: #64748b;
        margin-bottom: 0;
    }

    .login-body {
        padding: 28px;
    }

    .form-label {
        font-weight: 900;
        color: #243b53;
    }

    .form-control {
        border-radius: 16px;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
    }

    .form-control:focus {
        border-color: #7dd3fc;
        box-shadow: 0 0 0 0.18rem rgba(14, 165, 233, 0.13);
    }

    .form-check-input:checked {
        background-color: #3b82f6;
        border-color: #3b82f6;
    }

    .login-btn {
        border-radius: 999px;
        padding: 12px;
        font-weight: 900;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        border: 0;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.18);
    }

    .login-btn:hover {
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
    }

    .register-link {
        color: #2563eb;
        text-decoration: none;
        font-weight: 900;
    }

    .register-link:hover {
        color: #1d4ed8;
    }
</style>

<div class="container login-page mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="login-card">

                <div class="login-top">
                    <div class="login-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>

                    <h3 class="login-title">
                        تسجيل الدخول
                    </h3>

                    <p class="login-subtitle">
                        أهلاً بعودتك إلى EventRescue
                    </p>
                </div>

                <div class="login-body">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success rounded-4 text-center">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="••••••" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 login-btn">
                            <i class="bi bi-box-arrow-in-right"></i>
                            دخول
                        </button>

                        <div class="text-center mt-3">
                            <span class="text-muted">ليس لديك حساب؟</span>
                            <a asp-action="Register" class="register-link">إنشاء حساب</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}